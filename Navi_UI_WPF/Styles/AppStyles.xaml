<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:hc="https://handyorg.github.io/handycontrol">

    <!-- ══ Color Tokens ══════════════════════════════════════════════════ -->
    <Color x:Key="Brand">#1565C0</Color>
    <Color x:Key="BrandHover">#1976D2</Color>
    <Color x:Key="BrandPressed">#0D47A1</Color>
    <Color x:Key="Success">#388E3C</Color>
    <Color x:Key="Danger">#E53935</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="Background">#F4F6FA</Color>
    <Color x:Key="Border">#E5E7EB</Color>
    <Color x:Key="TextPrimary">#1F2937</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextMuted">#9CA3AF</Color>
    <Color x:Key="RowHover">#EFF6FF</Color>
    <Color x:Key="RowSelected">#DBEAFE</Color>

    <SolidColorBrush x:Key="BrandBrush" Color="{StaticResource Brand}"/>
    <SolidColorBrush x:Key="BrandHoverBrush" Color="{StaticResource BrandHover}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>

    <!-- ══ Drop Shadow ═══════════════════════════════════════════════════ -->
    <DropShadowEffect x:Key="CardShadow" Color="#000000" Direction="270"
                      ShadowDepth="2" BlurRadius="10" Opacity="0.07"/>
    <DropShadowEffect x:Key="HeaderShadow" Color="#000000" Direction="270"
                      ShadowDepth="1" BlurRadius="6" Opacity="0.06"/>

    <!-- ══ Button: Primary (HC) ════════════════════════════════════════ -->
    <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="hc:BorderElement.CornerRadius" Value="5"/>
    </Style>

    <!-- ══ Button: Ghost (HC default outline) ═════════════════════════ -->
    <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="hc:BorderElement.CornerRadius" Value="5"/>
    </Style>

    <!-- ══ Button: Icon (HC) ══════════════════════════════════════════ -->
    <Style x:Key="BtnIcon" TargetType="Button" BasedOn="{StaticResource ButtonIcon}">
        <Setter Property="Padding" Value="4"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="hc:BorderElement.CornerRadius" Value="4"/>
    </Style>

    <!-- ══ Button: Success (HC) ═══════════════════════════════════════ -->
    <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource ButtonSuccess}">
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="hc:BorderElement.CornerRadius" Value="5"/>
    </Style>

    <!-- ══ Button: Danger (HC) ════════════════════════════════════════ -->
    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource ButtonDanger}">
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="hc:BorderElement.CornerRadius" Value="5"/>
    </Style>

    <!-- ══ TextBox: Compact (HC) ══════════════════════════════════════ -->
    <Style x:Key="InputCompact" TargetType="TextBox" BasedOn="{StaticResource TextBoxExtend}">
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="hc:BorderElement.CornerRadius" Value="5"/>
    </Style>

    <!-- ══ ComboBox: Compact (HC) ═════════════════════════════════════ -->
    <Style x:Key="ComboCompact" TargetType="ComboBox" BasedOn="{StaticResource ComboBoxExtend}">
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="hc:BorderElement.CornerRadius" Value="5"/>
    </Style>

    <!-- ══ DataGrid (keep as-is, HC doesn't style DataGrid heavily) ═══ -->
    <Style x:Key="CompactGrid" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#F3F4F6"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowHeight" Value="36"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
    </Style>

    <!-- DataGrid column header style -->
    <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F8F9FA"/>
        <Setter Property="Foreground" Value="#6B7280"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SeparatorBrush" Value="#E5E7EB"/>
    </Style>

    <!-- DataGrid row style -->
    <Style x:Key="GridRow" TargetType="DataGridRow">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#EFF6FF"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DBEAFE"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DataGrid cell text styles -->
    <Style x:Key="CellText" TargetType="TextBlock">
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="CellTextMuted" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    </Style>

    <Style x:Key="CellTextBold" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="CellTextAccent" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
        <Setter Property="Foreground" Value="{StaticResource BrandBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ══ Card ══════════════════════════════════════════════════════════ -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

    <!-- ══ Form Label ════════════════════════════════════════════════════ -->
    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>

    <!-- ══ Section Title ══════════════════════════════════════════════════ -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- ══ Page Title ════════════════════════════════════════════════════ -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#1A1A2E"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ══ Chips/Tags ═════════════════════════════════════════════════════ -->
    <Style x:Key="ChipBlue" TargetType="Border">
        <Setter Property="Background" Value="#EFF6FF"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style x:Key="ChipGreen" TargetType="Border">
        <Setter Property="Background" Value="#F0FDF4"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style x:Key="ChipYellow" TargetType="Border">
        <Setter Property="Background" Value="#FFFBEB"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style x:Key="ChipRed" TargetType="Border">
        <Setter Property="Background" Value="#FEF2F2"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="6,2"/>
    </Style>

    <!-- ══ Toolbar bar (header) ══════════════════════════════════════════ -->
    <Style x:Key="Toolbar" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Effect" Value="{StaticResource HeaderShadow}"/>
    </Style>

    <!-- ══ Detail Drawer ════════════════════════════════════════════════ -->
    <Style x:Key="Drawer" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

</ResourceDictionary>
