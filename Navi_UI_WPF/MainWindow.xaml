<Window
    x:Class="Navi_UI_WPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Navi_UI_WPF.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Navi_UI_WPF"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Navi_UI_WPF.Views"
    xmlns:vm="clr-namespace:Navi_UI_WPF.ViewModels"
    Title="Navi Assembly Instructions"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <!--<DataTemplate DataType="{x:Type vm:HomeViewModel}">
        <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductAssemblyViewModel}">
        <views:ProductAssemblyView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NaviProductViewModel}">
        <views:NaviProductView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NaviItemViewModel}">
        <views:NaviItemView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NaviProductItemViewModel}">
        <views:NaviProductItemView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NaviHistoryViewModel}">
        <views:NaviHistoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ForceGaugeViewModel}">
        <views:ForceGaugeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InsertBallViewModel}">
        <views:InsertBallView />
        </DataTemplate>-->
    </Window.Resources>

    <!--<Window.DataContext>
    <vm:MainViewModel />
    </Window.DataContext>-->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <!--  Sidebar  -->
            <ColumnDefinition Width="*" />
            <!--  Content  -->
        </Grid.ColumnDefinitions>

        <!--  Sidebar  -->
        <Border Grid.Column="0" Background="#1565C0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="250" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMenuOpen}" Value="False">
                            <Setter Property="Width" Value="60" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Toggle Button  -->
                    <RowDefinition Height="Auto" />
                    <!--  Logo  -->
                    <RowDefinition Height="*" />
                    <!--  Menu  -->
                    <RowDefinition Height="Auto" />
                    <!--  Bottom Actions  -->
                </Grid.RowDefinitions>

                <!--  Toggle Button  -->

                <!--  Logo  -->
                <Grid Grid.Row="1" Margin="0,10,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Margin="15,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding ToggleMenuCommand}"
                        Content="☰"
                        Cursor="Hand"
                        FontSize="20"
                        Foreground="White" />

                    <StackPanel
                        Grid.Column="1"
                        Margin="15,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsMenuOpen, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock
                            HorizontalAlignment="Left"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="NAVI SYSTEM" />
                        <TextBlock
                            Margin="0,5,0,0"
                            HorizontalAlignment="Left"
                            FontSize="12"
                            Foreground="#90CAF9"
                            Text="Production Assistant" />
                    </StackPanel>
                </Grid>

                <!--  Logo Icon Only (Visible when collapsed - Optional/Removed if button is preferred)  -->
                <TextBlock
                    Grid.Row="1"
                    Margin="0,10,0,30"
                    HorizontalAlignment="Center"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="NS"
                    Visibility="Collapsed" />


                <!--  Menu Items  -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <StackPanel.Resources>
                            <Style BasedOn="{StaticResource {x:Type RadioButton}}" TargetType="RadioButton">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="Padding" Value="10" />
                                <Setter Property="Margin" Value="0,0,0,5" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border Padding="15,10" Background="{TemplateBinding Background}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter
                                                        Grid.Column="0"
                                                        Width="24"
                                                        HorizontalAlignment="Center"
                                                        Content="{TemplateBinding Tag}" />
                                                    <ContentPresenter
                                                        Grid.Column="1"
                                                        Margin="15,0,0,0"
                                                        Content="{TemplateBinding Content}"
                                                        Visibility="{Binding DataContext.IsMenuOpen, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1E88E5" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="#0D47A1" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </StackPanel.Resources>

                        <RadioButton
                            Command="{Binding NavigateToHomeCommand}"
                            Content="Trang Chủ"
                            IsChecked="True"
                            Tag="🏠" />

                        <RadioButton
                            Command="{Binding NavigateToAssemblyCommand}"
                            Content="Assembly"
                            Tag="📦" />
                        <RadioButton
                            Command="{Binding NavigateToInspectionCommand}"
                            Content="Inspection"
                            Tag="📦" />
                        <RadioButton
                            Command="{Binding NavigateToPackingCommand}"
                            Content="Packing"
                            Tag="📦" />

                        <!--  SubLeader+ only: Quản lý Sản phẩm  -->
                        <RadioButton
                            Command="{Binding NavigateToProductCommand}"
                            Content="Quản lý Sản phẩm"
                            Tag="🗂️"
                            Visibility="{Binding IsFullAccess, Converter={StaticResource BoolToVisibility}}" />

                        <!--  SubLeader+ only: Bước lắp ráp  -->
                        <RadioButton
                            Command="{Binding NavigateToItemCommand}"
                            Content="Bước lắp ráp"
                            Tag="🔧"
                            Visibility="{Binding IsFullAccess, Converter={StaticResource BoolToVisibility}}" />

                        <!--  SubLeader+ only: Liên kết SP-Bước  -->
                        <RadioButton
                            Command="{Binding NavigateToProductItemCommand}"
                            Content="Liên kết SP-Bước"
                            Tag="🔗"
                            Visibility="{Binding IsFullAccess, Converter={StaticResource BoolToVisibility}}" />

                        <!--  SubLeader+ only: Lịch sử thao tác  -->
                        <RadioButton
                            Command="{Binding NavigateToHistoryCommand}"
                            Content="Lịch sử thao tác"
                            Tag="📋"
                            Visibility="{Binding IsFullAccess, Converter={StaticResource BoolToVisibility}}" />

                        <!--  Tất cả: Force Gauge  -->
                        <RadioButton
                            Command="{Binding NavigateToForceGaugeCommand}"
                            Content="Force Gauge"
                            Tag="📈" />

                        <RadioButton
                            Command="{Binding NavigateToInsertBallCommand}"
                            Content="Insert Ball"
                            Tag="🔵" />

                        <RadioButton Content="RS232" Tag="⚙️" />
                        <!--  Tất cả: Cài Đặt  -->
                        <RadioButton Content="Cài Đặt" Tag="⚙️" />

                        <!--  Tất cả: Trợ Giúp  -->
                        <RadioButton Content="Trợ Giúp" Tag="❓" />
                    </StackPanel>
                </ScrollViewer>


                <!--  Bottom Actions  -->
                <StackPanel Grid.Row="3" Margin="0,0,0,10">

                    <!--  User Info Card (chỉ hiện khi menu mở)  -->
                    <Border
                        Margin="10,0,10,10"
                        Padding="10,8"
                        Background="#0D47A1"
                        CornerRadius="6"
                        Visibility="{Binding IsMenuOpen, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    FontSize="14"
                                    Foreground="#90CAF9"
                                    Text="👤 " />
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="{Binding CurrentUserName}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock
                                Margin="20,2,0,0"
                                FontSize="11"
                                Foreground="#64B5F6"
                                Text="{Binding CurrentUserRole}" />
                        </StackPanel>
                    </Border>

                    <!--  Logout Button  -->
                    <Button
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding LogoutCommand}"
                        Foreground="#EF9A9A">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Width="24"
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Text="🔓" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="15,0,0,0"
                                VerticalAlignment="Center"
                                Text="Đăng Xuất"
                                FontSize="14"
                                Visibility="{Binding IsMenuOpen, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </Button>

                    <!--  Exit Button  -->
                    <Button
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding ExitCommand}"
                        Foreground="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Width="24"
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Text="🚪" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="15,0,0,0"
                                VerticalAlignment="Center"
                                Text="Thoát"
                                FontSize="14"
                                Visibility="{Binding IsMenuOpen, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Content Area  -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" />

        <!--  Growl Container  -->
        <ScrollViewer Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" IsHitTestVisible="False" VerticalScrollBarVisibility="Hidden">
            <StackPanel hc:Growl.Token="MainGrowl" VerticalAlignment="Top"/>
        </ScrollViewer>
    </Grid>
</Window>
