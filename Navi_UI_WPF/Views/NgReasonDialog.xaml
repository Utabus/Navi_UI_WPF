<Window
    x:Class="Navi_UI_WPF.Views.NgReasonDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Lý do NG (Lỗi)"
    Width="450"
    Height="Auto"
    MinWidth="400"
    Background="#FAFAFA"
    AllowsTransparency="True"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <hc:String2VisibilityConverter x:Key="String2VisibilityConverter" />
    </Window.Resources>

    <Border
        Margin="10"
        Background="White"
        BorderBrush="#eeeeee"
        BorderThickness="1"
        CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.2"
                ShadowDepth="3" />
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  Title  -->
                <RowDefinition Height="Auto" />
                <!--  Reason Buttons  -->
                <RowDefinition Height="Auto" />
                <!--  Custom Reason Input  -->
                <RowDefinition Height="Auto" />
                <!--  Actions  -->
            </Grid.RowDefinitions>

            <!--  Header  -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="#C62828"
                    Text="⚠️ Xác nhận lỗi (NG)" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="13"
                    Foreground="#757575"
                    Text="Vui lòng chọn lý do phát hiện lỗi cho sản phẩm này:" />
            </StackPanel>

            <!--  Reason Selection  -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Reasons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox
                            Margin="0,0,16,16"
                            FontSize="16"
                            Content="{Binding Text}"
                            IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                            Style="{DynamicResource CheckBoxExtend}">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                            </CheckBox.LayoutTransform>
                        </CheckBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Custom Reason  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,10,0,20"
                Visibility="{Binding IsOtherSelected, Converter={StaticResource BoolToVisibility}}">
                <hc:TextBox
                    hc:InfoElement.Placeholder="Nhập lý do chi tiết tại đây..."
                    hc:InfoElement.Title="Lý do khác"
                    hc:TitleElement.TitlePlacement="Top"
                    Text="{Binding CustomReason, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!--  Actions  -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    hc:BorderElement.CornerRadius="8"
                    Click="Cancel_Click"
                    Content="Hủy bỏ"
                    Style="{StaticResource BtnGhost}" />

                <Button
                    Grid.Column="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    hc:BorderElement.CornerRadius="8"
                    Command="{Binding ConfirmCommand}"
                    Content="Xác nhận lưu NG"
                    Style="{StaticResource BtnDanger}" />
            </Grid>
        </Grid>
    </Border>
</Window>
