<UserControl x:Class="Navi_UI_WPF.Views.InsertBallView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Navi_UI_WPF.Views"
             xmlns:vm="clr-namespace:Navi_UI_WPF.ViewModels"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="*" />    <!-- Content -->
        </Grid.RowDefinitions> 

        <!-- ══ Header Area ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#FFF8E1" Padding="20,12" BorderBrush="#FFD54F" BorderThickness="0,0,0,2">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SỐ ORDER: " Foreground="#D32F2F" FontWeight="Bold" FontSize="16" />
                    <TextBlock Text="{Binding OrderNumber}" Foreground="#1565C0" FontWeight="Black" FontSize="20" Margin="5,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TÊN SP: " Foreground="#D32F2F" FontWeight="Bold" FontSize="16" />
                    <TextBlock Text="{Binding ProductName}" Foreground="#1565C0" FontWeight="Black" FontSize="20" Margin="5,0,0,0"/>
                </StackPanel>

                <Border Grid.Column="4" Background="#D32F2F" CornerRadius="15" Padding="15,4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Count: " Foreground="White" FontWeight="Bold" FontSize="14" />
                        <TextBlock Text="{Binding Count}" Foreground="White" FontWeight="Black" FontSize="20" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ Main Content ══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="200" /> <!-- Right Panel - wider for better buttons -->
            </Grid.ColumnDefinitions>

            <!-- LEFT Area: Ball Selection Card -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,15,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Title Section -->
                    <Grid Grid.Row="0" Margin="0,0,0,25">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Border Width="12" Height="12" Background="#D32F2F" CornerRadius="2" Margin="2,0"/>
                            <Border Width="12" Height="12" Background="#1565C0" CornerRadius="2" Margin="2,0"/>
                        </StackPanel>
                        
                        <TextBlock Text="{Binding SizeBallLabel}" 
                                   HorizontalAlignment="Center" 
                                   Foreground="#D32F2F" 
                                   FontSize="42" 
                                   FontWeight="Black" />
                    </Grid>

                    <!-- Ball Grid (3x7) -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding SizeBallValues}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0" 
                                        Height="110"
                                        Width="100"
                                        Command="{Binding DataContext.SelectSizeBallCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        hc:BorderElement.CornerRadius="8"
                                        BorderThickness="1">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
                                            <Setter Property="Background" Value="White" />
                                            <Setter Property="BorderBrush" Value="#E0E0E0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#1565C0" />
                                                    <Setter Property="BorderBrush" Value="#0D47A1" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsSelected}" Value="False" />
                                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Background" Value="#F5F5F5" />
                                                    <Setter Property="BorderBrush" Value="#1565C0" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    
                                    <TextBlock Text="{Binding DisplayText}" 
                                               FontSize="28" 
                                               FontWeight="Bold" 
                                               VerticalAlignment="Center" 
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#424242" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- RIGHT Area: Status & Controls -->
            <StackPanel Grid.Column="1">
                <!-- Status Card -->
                <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,15">
                    <StackPanel>
                        <Border Background="#F9FAFB" Padding="8" CornerRadius="8,8,0,0" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                            <TextBlock Text="MÁY CHẠY" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#6B7280"/>
                        </Border>
                        <Border Padding="15">
                            <Grid>
                                <Ellipse Width="12" Height="12" Fill="{Binding StatusColor}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <Ellipse.Effect>
                                        <BlurEffect Radius="4" />
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="{Binding Status}" 
                                           HorizontalAlignment="Center" 
                                           FontSize="26" 
                                           FontWeight="Black" 
                                           Foreground="{Binding StatusColor}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Table Selection Card -->
                <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,15">
                    <StackPanel>
                        <Border Background="#F9FAFB" Padding="8" CornerRadius="8,8,0,0" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                            <TextBlock Text="BÀN LÀM VIỆC" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Foreground="#6B7280"/>
                        </Border>
                        <ItemsControl ItemsSource="{Binding TableValues}" Margin="10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,2" 
                                            Height="45"
                                            Command="{Binding DataContext.SelectTableCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            hc:BorderElement.CornerRadius="6">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
                                                <Setter Property="Background" Value="White" />
                                                <Setter Property="BorderBrush" Value="#E5E7EB" />
                                                <Setter Property="Content">
                                                    <Setter.Value>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Bàn " FontSize="14" />
                                                            <TextBlock Text="{Binding Number}" FontSize="18" FontWeight="Bold" />
                                                        </StackPanel>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#1565C0" />
                                                        <Setter Property="BorderBrush" Value="#0D47A1" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Control Buttons Area -->
                <Border Style="{StaticResource Card}" Padding="15">
                    <StackPanel>
                        <Button Style="{StaticResource BtnSuccess}" 
                                Command="{Binding StartCommand}"
                                Height="60" 
                                Margin="0,0,0,12"
                                hc:BorderElement.CornerRadius="10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="START" FontSize="20" FontWeight="Black" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Style="{StaticResource BtnDanger}" 
                                Command="{Binding StopCommand}"
                                Height="60"
                                hc:BorderElement.CornerRadius="10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="■" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="STOP" FontSize="20" FontWeight="Black" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>

</UserControl>
