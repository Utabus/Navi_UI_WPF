<UserControl x:Class="Navi_UI_WPF.Views.NaviHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Navi_UI_WPF.ViewModels"
             xmlns:conv="clr-namespace:Navi_UI_WPF.Converters"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1100"
             Background="{StaticResource BackgroundBrush}">
    <UserControl.DataContext>
        <vm:NaviHistoryViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Stat bar -->
            <RowDefinition Height="*"/>
            <!-- Table + Drawer -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource Toolbar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="📋 Lịch sử" Style="{StaticResource PageTitle}" Margin="0,0,16,0"/>

                <TextBox Grid.Column="1" Style="{StaticResource InputCompact}" Margin="0,0,6,0"
                         Text="{Binding FilterCodeNV, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding FilterByCodeNVCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <TextBox Grid.Column="2" Style="{StaticResource InputCompact}" Margin="0,0,6,0"
                         Text="{Binding FilterPO, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding FilterByPOCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <TextBox Grid.Column="3" Style="{StaticResource InputCompact}" Margin="0,0,6,0"
                         Text="{Binding FilterProductItemId}"/>

                <TextBlock Grid.Column="4" Text="{Binding StatusMessage}"
                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="4,0"/>

                <Button Grid.Column="5" Content="🔍" Style="{StaticResource BtnGhost}"
                        Command="{Binding FilterByCodeNVCommand}" Padding="10,5" Margin="0,0,6,0"/>
                <Button Grid.Column="6" Content="✕" Style="{StaticResource BtnGhost}"
                        Command="{Binding ClearFilterCommand}" Padding="8,5" Margin="0,0,6,0"/>
                <Button Grid.Column="7" Content="+ Ghi log" Style="{StaticResource BtnPrimary}"
                        Command="{Binding AddCommand}"/>
            </Grid>
        </Border>

        <!-- ── Stat bar ────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="12,10,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Stat: Total -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="14,8"
                    Margin="0,0,8,0" Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Tổng bản ghi" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrandBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Stat: Employees -->
            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="14,8"
                    Margin="0,0,8,0" Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="👷" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Nhân viên" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding UniqueEmployeeCount}" FontSize="20" FontWeight="Bold" Foreground="#388E3C"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Stat: PO -->
            <Border Grid.Column="2" Background="White" CornerRadius="6" Padding="14,8"
                    Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🏭" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="PO đang chạy" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ActivePOCount}" FontSize="20" FontWeight="Bold" Foreground="#F57C00"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Table + Drawer ─────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="12,8,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}"
                    Margin="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}, ConverterParameter='0,0,8,0'}">
                <DataGrid Style="{StaticResource CompactGrid}"
                          ItemsSource="{Binding HistoryRecords}"
                          SelectedItem="{Binding SelectedRecord}"
                          ColumnHeaderStyle="{StaticResource GridHeader}"
                          RowStyle="{StaticResource GridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextMuted}"/>
                        <DataGridTextColumn Header="MÃ NV" Binding="{Binding CodeNV}" Width="75" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextAccent}"/>
                        <DataGridTextColumn Header="TÊN NV" Binding="{Binding NameNV}" Width="*" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellText}"/>
                        <DataGridTextColumn Header="PO" Binding="{Binding PO}" Width="130" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextMuted}"/>
                        <DataGridTextColumn Header="BƯỚC" Binding="{Binding Step}" Width="60" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextMuted}"/>
                        <DataGridTemplateColumn Header="LOẠI" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border VerticalAlignment="Center" Margin="8,0" CornerRadius="10" Padding="6,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#EFF6FF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="CHECK">
                                                        <Setter Property="Background" Value="#F0FDF4"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="CONFIRM">
                                                        <Setter Property="Background" Value="#FFFBEB"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="REJECT">
                                                        <Setter Property="Background" Value="#FEF2F2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#1D4ED8"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="CHECK">
                                                            <Setter Property="Foreground" Value="#15803D"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="CONFIRM">
                                                            <Setter Property="Foreground" Value="#D97706"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="REJECT">
                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="THỜI GIAN" Binding="{Binding Cdt, StringFormat=HH:mm dd/MM}" Width="110" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextMuted}"/>
                        <DataGridTemplateColumn Header="" Width="65">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Style="{StaticResource BtnIcon}" Content="✏️"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Style="{StaticResource BtnIcon}" Content="🗑️"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Detail drawer -->
            <Border Grid.Column="1" Width="290" Style="{StaticResource Drawer}"
                    Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionTitle}">
                                    <Setter Property="Text" Value="Chi tiết thao tác"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="Chỉnh sửa log"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Style="{StaticResource BtnIcon}" HorizontalAlignment="Right" Content="✕"
                                Foreground="{StaticResource TextMutedBrush}" Command="{Binding CancelEditCommand}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Tên nhân viên" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding EditNameNV}" Style="{StaticResource InputCompact}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="Mã NV" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding EditCodeNV}" Style="{StaticResource InputCompact}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Production Order (PO)" Style="{StaticResource FormLabel}"/>
                            <TextBox Text="{Binding EditPO}" Style="{StaticResource InputCompact}" Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Bước" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding EditStep}" Style="{StaticResource InputCompact}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="Số lượng" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding EditCount}" Style="{StaticResource InputCompact}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Loại hành động" Style="{StaticResource FormLabel}"/>
                            <ComboBox ItemsSource="{Binding AvailableTypes}" SelectedItem="{Binding EditType}"
                                      Style="{StaticResource ComboCompact}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Hủy" Style="{StaticResource BtnGhost}" Margin="0,0,6,0"
                                Command="{Binding CancelEditCommand}"/>
                        <Button Content="Lưu" Style="{StaticResource BtnPrimary}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
