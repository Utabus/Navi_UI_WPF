<UserControl
    x:Class="Navi_UI_WPF.Views.NaviHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Navi_UI_WPF.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Navi_UI_WPF.ViewModels"
    d:DesignHeight="750"
    d:DesignWidth="1100"
    Background="{StaticResource BackgroundBrush}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Toolbar  -->
            <RowDefinition Height="Auto" />
            <!--  Stat bar  -->
            <RowDefinition Height="*" />
            <!--  Table + Drawer  -->
        </Grid.RowDefinitions>

        <!--  ── Toolbar ───────────────────────────────────────────────────  -->
        <Border Grid.Row="0" Style="{StaticResource Toolbar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,16,0"
                    Style="{StaticResource PageTitle}"
                    Text="📋 Lịch sử" />

                <TextBox
                    Grid.Column="1"
                    Margin="0,0,6,0"
                    Style="{StaticResource InputCompact}"
                    Text="{Binding FilterCodeNV, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding FilterByCodeNVCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <TextBox
                    Grid.Column="2"
                    Margin="0,0,6,0"
                    Style="{StaticResource InputCompact}"
                    Text="{Binding FilterPO, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding FilterByPOCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <TextBox
                    Grid.Column="3"
                    Margin="0,0,6,0"
                    Style="{StaticResource InputCompact}"
                    Text="{Binding FilterProductItemId}" />

                <TextBlock
                    Grid.Column="4"
                    Margin="4,0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{StaticResource TextMutedBrush}"
                    Text="{Binding StatusMessage}" />

                <Button
                    Grid.Column="5"
                    Margin="0,0,6,0"
                    Padding="10,5"
                    Command="{Binding FilterByCodeNVCommand}"
                    Content="🔍"
                    Style="{StaticResource BtnGhost}" />
                <Button
                    Grid.Column="6"
                    Margin="0,0,6,0"
                    Padding="8,5"
                    Command="{Binding ClearFilterCommand}"
                    Content="✕"
                    Style="{StaticResource BtnGhost}" />
                <Button
                    Grid.Column="7"
                    Command="{Binding AddCommand}"
                    Content="+ Ghi log"
                    Style="{StaticResource BtnPrimary}" />
            </Grid>
        </Border>

        <!--  ── Stat bar ──────────────────────────────────────────────────  -->
        <Grid Grid.Row="1" Margin="12,10,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Stat: Total  -->
            <Border
                Grid.Column="0"
                Margin="0,0,8,0"
                Padding="14,8"
                Background="White"
                CornerRadius="6"
                Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Text="📊" />
                    <StackPanel>
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Tổng bản ghi" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{StaticResource BrandBrush}"
                            Text="{Binding TotalCount}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Stat: Employees  -->
            <Border
                Grid.Column="1"
                Margin="0,0,8,0"
                Padding="14,8"
                Background="White"
                CornerRadius="6"
                Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Text="👷" />
                    <StackPanel>
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Nhân viên" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#388E3C"
                            Text="{Binding UniqueEmployeeCount}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--  Stat: PO  -->
            <Border
                Grid.Column="2"
                Padding="14,8"
                Background="White"
                CornerRadius="6"
                Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="14"
                        Text="🏭" />
                    <StackPanel>
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="PO đang chạy" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="#F57C00"
                            Text="{Binding ActivePOCount}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!--  ── Table + Drawer ───────────────────────────────────────────  -->
        <Grid Grid.Row="2" Margin="12,8,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Margin="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}, ConverterParameter='0,0,8,0'}" Style="{StaticResource Card}">
                <DataGrid
                    ColumnHeaderStyle="{StaticResource GridHeader}"
                    ItemsSource="{Binding HistoryRecords}"
                    RowStyle="{StaticResource GridRow}"
                    SelectedItem="{Binding SelectedRecord}"
                    Style="{StaticResource CompactGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding Id}"
                            ElementStyle="{StaticResource CellTextMuted}"
                            Header="ID"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="75"
                            Binding="{Binding CodeNV}"
                            ElementStyle="{StaticResource CellTextAccent}"
                            Header="MÃ NV"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding NameNV}"
                            ElementStyle="{StaticResource CellText}"
                            Header="TÊN NV"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="130"
                            Binding="{Binding PO}"
                            ElementStyle="{StaticResource CellTextMuted}"
                            Header="PO"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="60"
                            Binding="{Binding Step}"
                            ElementStyle="{StaticResource CellTextMuted}"
                            Header="BƯỚC"
                            IsReadOnly="True" />
                        <DataGridTemplateColumn Width="80" Header="LOẠI">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="8,0"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        CornerRadius="10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#EFF6FF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="CHECK">
                                                        <Setter Property="Background" Value="#F0FDF4" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="CONFIRM">
                                                        <Setter Property="Background" Value="#FFFBEB" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="REJECT">
                                                        <Setter Property="Background" Value="#FEF2F2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Text="{Binding Type}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#1D4ED8" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="CHECK">
                                                            <Setter Property="Foreground" Value="#15803D" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="CONFIRM">
                                                            <Setter Property="Foreground" Value="#D97706" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="REJECT">
                                                            <Setter Property="Foreground" Value="#DC2626" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding Cdt, StringFormat=HH:mm dd/MM}"
                            ElementStyle="{StaticResource CellTextMuted}"
                            Header="THỜI GIAN"
                            IsReadOnly="True" />
                        <DataGridTemplateColumn Width="65" Header="">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Content="✏️"
                                            Style="{StaticResource BtnIcon}" />
                                        <Button
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Content="🗑️"
                                            Style="{StaticResource BtnIcon}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!--  Detail drawer  -->
            <Border
                Grid.Column="1"
                Width="290"
                Style="{StaticResource Drawer}"
                Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style BasedOn="{StaticResource SectionTitle}" TargetType="TextBlock">
                                    <Setter Property="Text" Value="Chi tiết thao tác" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="Chỉnh sửa log" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button
                            HorizontalAlignment="Right"
                            Command="{Binding CancelEditCommand}"
                            Content="✕"
                            Foreground="{StaticResource TextMutedBrush}"
                            Style="{StaticResource BtnIcon}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Style="{StaticResource FormLabel}" Text="Tên nhân viên" />
                                    <TextBox Style="{StaticResource InputCompact}" Text="{Binding EditNameNV}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Style="{StaticResource FormLabel}" Text="Mã NV" />
                                    <TextBox Style="{StaticResource InputCompact}" Text="{Binding EditCodeNV}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Style="{StaticResource FormLabel}" Text="Production Order (PO)" />
                            <TextBox
                                Margin="0,0,0,8"
                                Style="{StaticResource InputCompact}"
                                Text="{Binding EditPO}" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Style="{StaticResource FormLabel}" Text="Bước" />
                                    <TextBox Style="{StaticResource InputCompact}" Text="{Binding EditStep}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Style="{StaticResource FormLabel}" Text="Số lượng" />
                                    <TextBox Style="{StaticResource InputCompact}" Text="{Binding EditCount}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Style="{StaticResource FormLabel}" Text="Loại hành động" />
                            <ComboBox
                                ItemsSource="{Binding AvailableTypes}"
                                SelectedItem="{Binding EditType}"
                                Style="{StaticResource ComboCompact}" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,6,0"
                            Command="{Binding CancelEditCommand}"
                            Content="Hủy"
                            Style="{StaticResource BtnGhost}" />
                        <Button
                            Command="{Binding SaveCommand}"
                            Content="Lưu"
                            Style="{StaticResource BtnPrimary}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
