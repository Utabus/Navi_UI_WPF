<UserControl
    x:Class="Navi_UI_WPF.Views.PackingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Navi_UI_WPF.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Navi_UI_WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Navi_UI_WPF.ViewModels"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="#FAFAFA"
    mc:Ignorable="d"
    FocusManager.FocusedElement="{Binding ElementName=PoTextBox}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="LocalBoolToVisibility" />
        <conv:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility" />
        <conv:StepStatusToIconConverter x:Key="StepStatusToIcon" />

        <Style x:Key="AssemblyRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource GridRow}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Background" Value="#F1F8E9" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsNg}" Value="True">
                    <Setter Property="Background" Value="#FFEBEE" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Opacity" Value="0.6" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Background" Value="#E3F2FD" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Header  -->
            <RowDefinition Height="*" />
            <!--  Content  -->
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Padding="16,10"
            Background="{StaticResource BrandBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Form Title -->
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="20" />

                    <ColumnDefinition Width="Auto" />
                    <!--  PO Label  -->
                    <ColumnDefinition Width="200" />
                    <!--  PO TextBox  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  PO Info Labels  -->
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <!--  Manufa Reference Info  -->
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <!--  Spacer  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  Step Progress  -->
                </Grid.ColumnDefinitions>

                <!--  Form Title  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="20" FontWeight="Heavy" Foreground="White" Text="📦 Packing" VerticalAlignment="Center" />
                    <Border Width="1" Background="#50FFFFFF" Margin="20,0,0,0" Height="30" VerticalAlignment="Center" />
                </StackPanel>

                <!--  PO Label  -->
                <TextBlock
                    Grid.Column="2"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="PO" />

                <!--  PO Input TextBox  -->
                <hc:TextBox
                    x:Name="PoTextBox"
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    hc:InfoElement.Placeholder="Nhập số PO..."
                    FontSize="13"
                    Text="{Binding PoNumber, UpdateSourceTrigger=PropertyChanged}">
                    <hc:TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchPoCommand}" />
                    </hc:TextBox.InputBindings>
                </hc:TextBox>

                <!--  Manufa Reference Info  -->
                <StackPanel
                    Grid.Column="6"
                    VerticalAlignment="Center"
                    Margin="30 0 30 0"
                    Visibility="{Binding ProductName, Converter={StaticResource NullOrEmptyToVisibility}}">
                    <TextBlock
                        FontSize="10"
                        Foreground="#90CAF9"
                        Text="Tên hàng" />
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding ProductName}" />
                </StackPanel>

                <!--  Step Progress  -->
                <TextBlock
                    Grid.Column="8"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    FontSize="14"
                    Margin="10 0 0 0"
                    Foreground="#E3F2FD">
                    <Run Text="Bước " />
                    <Run FontWeight="Bold" Text="{Binding CurrentStepNumber, Mode=OneWay}" />
                    <Run Text=" / " />
                    <Run Text="{Binding TotalSteps, Mode=OneWay}" />
                </TextBlock>
            </Grid>
        </Border>

        <!--  Main Content  -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" MinWidth="250" />
                <!--  Step List LEFT  -->
                <ColumnDefinition Width="Auto" />
                <!--  Splitter  -->
                <ColumnDefinition Width="4*" MinWidth="500" />
                <!--  Step Detail RIGHT  -->
            </Grid.ColumnDefinitions>

            <!--  Grid Splitter  -->
            <GridSplitter
                Grid.Column="1"
                Width="6"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="Transparent"
                ShowsPreview="True" />

            <!--  ══ Step List (LEFT) ═════════════════════════════════════  -->
            <Border
                Grid.Column="0"
                Padding="12"
                Background="White"
                CornerRadius="8"
                Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!--  Title  -->
                        <RowDefinition Height="Auto" />
                        <!--  SearchBar  -->
                        <RowDefinition Height="*" />
                        <!--  DataGrid  -->
                        <RowDefinition Height="Auto" />
                        <!--  Footer Nav  -->
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="DANH SÁCH BƯỚC ĐÓNG GÓI" />

                    <hc:SearchBar
                        Grid.Row="1"
                        Height="32"
                        Margin="0,0,0,10"
                        hc:InfoElement.Placeholder="Tìm kiếm bước..."
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <DataGrid
                        x:Name="StepsDataGrid"
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        ColumnHeaderStyle="{StaticResource GridHeader}"
                        IsReadOnly="True"
                        CanUserSortColumns="False"
                        CanUserReorderColumns="False"
                        ItemsSource="{Binding StepsView}"
                        RowStyle="{StaticResource AssemblyRowStyle}"
                        SelectedItem="{Binding CurrentStep, Mode=TwoWay}"
                        Style="{StaticResource CompactGrid}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="55" Header="BƯỚC">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="26"
                                            Height="26"
                                            HorizontalAlignment="Center"
                                            CornerRadius="13">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#BDBDBD" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Background" Value="#C8E6C9" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsNg}" Value="True">
                                                            <Setter Property="Background" Value="#FFCDD2" />
                                                            <Setter Property="BorderBrush" Value="#C62828" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BrandBrush}" />
                                                            <Setter Property="BorderThickness" Value="0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Text="{Binding StepNumber}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Foreground" Value="#2E7D32" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsNg}" Value="True">
                                                                <Setter Property="Foreground" Value="#C62828" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                <Setter Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Description}"
                                ElementStyle="{StaticResource CellText}"
                                Header="MÔ TẢ" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Command="{Binding PreviousStepCommand}"
                            Content="◄ Bước trước"
                            Style="{StaticResource BtnGhost}" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding NextStepCommand}"
                            Content="Bước sau ►"
                            Style="{StaticResource BtnPrimary}" />
                    </Grid>
                </Grid>
            </Border>

            <!--  ══ Step Detail (RIGHT) ══════════════════════════════════  -->
            <Border
                Grid.Column="2"
                Background="White"
                CornerRadius="8"
                Effect="{StaticResource CardShadow}"
                Visibility="{Binding HasCurrentStep, Converter={StaticResource LocalBoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="5*" />
                        <RowDefinition Height="Auto" MaxHeight="250" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="16,12,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center">
                            <Run
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{StaticResource BrandBrush}"
                                Text="Bước " />
                            <Run
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{StaticResource BrandBrush}"
                                Text="{Binding CurrentStepNumber, StringFormat={}{0}, Mode=OneWay}" />
                            <Run
                                FontSize="14"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text=" — " />
                            <Run
                                FontSize="15"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{Binding CurrentStep.Description}" />
                        </TextBlock>
                    </Grid>

                    <Rectangle
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Height="1"
                        Margin="16,0,16,0"
                        VerticalAlignment="Bottom"
                        Fill="{StaticResource BorderBrush}" />

                    <Grid Grid.Row="1" Margin="16,10,16,10">
                        <Border
                            Background="#F5F5F5"
                            ClipToBounds="True"
                            CornerRadius="6"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Visibility="{Binding CurrentStep.HasImages, Converter={StaticResource LocalBoolToVisibility}}">
                            <Image
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="{Binding CurrentStep.Images, TargetNullValue={x:Null}}"
                                Stretch="Uniform" />
                        </Border>

                        <Border
                            Background="#F0F0F0"
                            CornerRadius="6"
                            Visibility="{Binding CurrentStep.HasImages, Converter={StaticResource LocalBoolToVisibility}, ConverterParameter=Invert}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="40"
                                    Foreground="#BDBDBD"
                                    Text="📦" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#9E9E9E"
                                    Text="Hình ảnh minh họa đóng gói" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        Padding="16,12,16,12"
                        BorderBrush="{StaticResource BorderBrush}" 
                        BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <Border 
                                    Padding="12,8"
                                    Background="#FAFAFA"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4" Visibility="{Binding CurrentStep.HasNote, Converter={StaticResource LocalBoolToVisibility}}">
                                            <TextBlock Text="※ CHÚ Ý: " FontWeight="Bold" Foreground="#E65100" FontSize="12" />
                                            <TextBlock Text="{Binding CurrentStep.Note}" FontSize="12" Foreground="#BF360C" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <Button Height="46"
                                        Background="#F44336"
                                        Foreground="White"
                                        BorderBrush="#B71C1C"
                                        BorderThickness="0,0,0,4"
                                        Cursor="Hand"
                                        Margin="0,0,0,8"
                                        Command="{Binding ConfirmNgCommand}"
                                        hc:BorderElement.CornerRadius="8">
                                    <Button.Effect>
                                        <DropShadowEffect BlurRadius="8" Direction="270" Opacity="0.2" ShadowDepth="2" />
                                    </Button.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="20" Text="✖ " VerticalAlignment="Center" FontWeight="Black" />
                                        <TextBlock FontSize="16" FontWeight="Black" Text="NG" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Height="46"
                                        Background="#4CAF50"
                                        Foreground="White"
                                        BorderBrush="#1B5E20"
                                        BorderThickness="0,0,0,4"
                                        Cursor="Hand"
                                        Command="{Binding ConfirmOkCommand}"
                                        hc:BorderElement.CornerRadius="8">
                                    <Button.Effect>
                                        <DropShadowEffect BlurRadius="8" Direction="270" Opacity="0.2" ShadowDepth="2" />
                                    </Button.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="20" Text="✔ " VerticalAlignment="Center" FontWeight="Black" />
                                        <TextBlock FontSize="16" FontWeight="Black" Text="OK" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
