<UserControl x:Class="Navi_UI_WPF.Views.NaviProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:vm="clr-namespace:Navi_UI_WPF.ViewModels"
             xmlns:conv="clr-namespace:Navi_UI_WPF.Converters"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1100"
             Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource Toolbar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="📦 Sản phẩm" Style="{StaticResource PageTitle}" Margin="0,0,16,0"/>

                <hc:TextBox Grid.Column="1" Style="{StaticResource InputCompact}"
                         Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         hc:InfoElement.Placeholder="Tìm sản phẩm..."
                         Margin="0,0,6,0">
                    <hc:TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </hc:TextBox.InputBindings>
                </hc:TextBox>

                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}"
                           FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="8,0"/>

                <Button Grid.Column="3" Content="🔍" Style="{StaticResource BtnGhost}"
                        Command="{Binding SearchCommand}" Margin="0,0,6,0" Padding="10,5"/>
                <Button Grid.Column="4" Content="📥 Excel" Style="{StaticResource BtnSuccess}"
                        Margin="0,0,6,0"/>
                <Button Grid.Column="5" Content="+ Thêm" Style="{StaticResource BtnPrimary}"
                        Command="{Binding AddCommand}"/>
            </Grid>
        </Border>

        <!-- ── Body ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}, ConverterParameter=300}"/>
            </Grid.ColumnDefinitions>

            <!-- Table card -->
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <DataGrid Style="{StaticResource CompactGrid}"
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          ColumnHeaderStyle="{StaticResource GridHeader}"
                          RowStyle="{StaticResource GridRow}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextMuted}"/>
                        <DataGridTextColumn Header="TÊN SẢN PHẨM" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextBold}"/>
                        <DataGridTextColumn Header="MÔ TẢ" Binding="{Binding Description}" Width="2*" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextMuted}"/>
                        <DataGridTextColumn Header="NGÀY TẠO" Binding="{Binding Cdt, StringFormat=dd/MM/yyyy}" Width="100" IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextMuted}"/>
                        <DataGridTemplateColumn Header="" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Style="{StaticResource BtnIcon}" Content="✏️"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Style="{StaticResource BtnIcon}" Content="🗑️" Foreground="#E53935"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Detail drawer -->
            <Border Grid.Column="1" Style="{StaticResource Drawer}"
                    Visibility="{Binding IsDetailVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Drawer header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SectionTitle}">
                                    <Setter Property="Text" Value="Các bước lắp ráp thuộc sản phẩm"/>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Style="{StaticResource BtnIcon}" HorizontalAlignment="Right"
                                Content="✕" Foreground="{StaticResource TextMutedBrush}"
                                Command="{Binding ClearSelectionCommand}"/>
                    </Grid>

                    <!-- Product Items Grid -->
                    <Grid Grid.Row="1" Margin="0,5,0,0">
                        <DataGrid Style="{StaticResource CompactGrid}"
                                  ItemsSource="{Binding SelectedProductWithItems.Items}"
                                  ColumnHeaderStyle="{StaticResource GridHeader}"
                                  RowStyle="{StaticResource GridRow}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  MinHeight="150"
                                  HorizontalScrollBarVisibility="Auto"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="STEP" Binding="{Binding Step}" Width="50" ElementStyle="{StaticResource CellTextMuted}"/>
                                <DataGridTextColumn Header="MÔ TẢ" Binding="{Binding Description}" Width="*" ElementStyle="{StaticResource CellTextBold}"/>
                                <DataGridTextColumn Header="BU LÔNG" Binding="{Binding Bolts}" Width="80" ElementStyle="{StaticResource CellTextMuted}"/>
                                <DataGridTextColumn Header="LỰC SIẾT" Binding="{Binding Force}" Width="70" ElementStyle="{StaticResource CellTextMuted}"/>
                                <DataGridTextColumn Header="TYPE" Binding="{Binding Type}" Width="80" ElementStyle="{StaticResource CellTextMuted}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Đóng" Style="{StaticResource BtnGhost}"
                                Command="{Binding ClearSelectionCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
