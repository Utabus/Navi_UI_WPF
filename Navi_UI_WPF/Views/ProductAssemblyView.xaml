<UserControl
    x:Class="Navi_UI_WPF.Views.ProductAssemblyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Navi_UI_WPF.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Navi_UI_WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Navi_UI_WPF.ViewModels"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="#FAFAFA"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:ProductAssemblyViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="LocalBoolToVisibility" />
        <conv:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility" />
        <conv:StepStatusToIconConverter x:Key="StepStatusToIcon" />

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Header  -->
            <RowDefinition Height="*" />
            <!--  Content  -->
            <RowDefinition Height="Auto" />
            <!--  Footer/Progress  -->
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Padding="10,10"
            Background="#2196F3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding ProductName}" />

                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding ProductName}" />
                    <TextBlock
                        Margin="0,5,0,0"
                        FontSize="14"
                        Foreground="#E3F2FD"
                        Text="{Binding Description}"
                        Visibility="{Binding Description, Converter={StaticResource NullOrEmptyToVisibility}}" />
                </StackPanel>


            </Grid>
        </Border>

        <!--  Loading Overlay  -->
        <Grid
            Grid.Row="1"
            Panel.ZIndex="999"
            Background="#80000000"
            Visibility="{Binding IsLoading, Converter={StaticResource LocalBoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="18"
                    Foreground="White"
                    Text="⏳ Đang tải dữ liệu..." />
            </StackPanel>
        </Grid>

        <!--  Error Message  -->
        <Border
            Grid.Row="1"
            Margin="20"
            Padding="20"
            Panel.ZIndex="998"
            Background="#FFEBEE"
            BorderBrush="#F44336"
            BorderThickness="2"
            Visibility="{Binding HasError, Converter={StaticResource LocalBoolToVisibility}}">
            <StackPanel>
                <TextBlock
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="#D32F2F"
                    Text="⚠️ Lỗi" />
                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="14"
                    Foreground="#C62828"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
                <Button
                    Margin="0,15,0,0"
                    Padding="10,5"
                    HorizontalAlignment="Left"
                    Command="{Binding LoadDataCommand}"
                    CommandParameter="{Binding ProductId}"
                    Content="🔄 Thử lại" />
            </StackPanel>
        </Border>

        <!--  Main Content  -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <!--  Step Display  -->
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="1.5*" />
                <!--  Step List  -->
            </Grid.ColumnDefinitions>

            <!--  Current Step Display  -->
            <Border
                Grid.Column="0"
                Padding="5"
                Background="White"
                CornerRadius="8"
                Effect="{StaticResource CardShadow}"
                Visibility="{Binding HasCurrentStep, Converter={StaticResource LocalBoolToVisibility}}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!--  Step Header  -->
                        <RowDefinition Height="*" />
                        <!--  Step Content  -->
                        <RowDefinition Height="Auto" />
                        <!--  Navigation  -->
                    </Grid.RowDefinitions>

                    <!--  Step Header  -->
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0">
                            <Run
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="#2196F3"
                                Text="Bước " />
                            <Run
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="#2196F3"
                                Text="{Binding CurrentStepNumber, StringFormat={}{0}, Mode=OneWay}" />
                            <Run
                                FontSize="16"
                                Foreground="#757575"
                                Text="/" />
                            <Run
                                FontSize="16"
                                Foreground="#757575"
                                Text="{Binding TotalSteps, StringFormat={}{0}, Mode=OneWay}" />
                        </TextBlock>



                        <CheckBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Content="✓ Hoàn thành"
                            FontSize="14"
                            IsChecked="{Binding CurrentStep.IsCompleted}" />
                    </Grid>

                    <!--  Step Content  -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!--  Image Display Area  -->
                            <Grid Height="400" Margin="0,0,0,20">
                                <!--  Actual Image  -->
                                <Border
                                    Background="#F5F5F5"
                                    ClipToBounds="True"
                                    CornerRadius="4"
                                    Visibility="{Binding CurrentStep.HasImages, Converter={StaticResource LocalBoolToVisibility}}">
                                    <Image
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="{Binding CurrentStep.Images}"
                                        Stretch="Uniform" />
                                </Border>

                                <!--  Placeholder (Visible only when HasImages is False)  -->
                                <Border
                                    Background="#E0E0E0"
                                    CornerRadius="4"
                                    Visibility="{Binding CurrentStep.HasImages, Converter={StaticResource LocalBoolToVisibility}, ConverterParameter=Invert}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock
                                            Margin="0,0,0,10"
                                            HorizontalAlignment="Center"
                                            FontSize="40"
                                            Foreground="#9E9E9E"
                                            Text="📷" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="16"
                                            Foreground="#757575"
                                            Text="Hình ảnh minh họa" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!--  Description  -->
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="#424242"
                                Text="📝 Mô tả:" />
                            <TextBlock
                                Margin="0,0,0,20"
                                FontSize="14"
                                Foreground="#212121"
                                Text="{Binding CurrentStep.Description}"
                                TextWrapping="Wrap" />

                            <!--  Note  -->
                            <StackPanel Visibility="{Binding CurrentStep.HasNote, Converter={StaticResource LocalBoolToVisibility}}">
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="#FF6F00"
                                    Text="※ Chú ý:" />
                                <TextBlock
                                    Margin="0,0,0,20"
                                    FontSize="14"
                                    Foreground="#E65100"
                                    Text="{Binding CurrentStep.Note}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <!--  Technical Specs  -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Bolts  -->
                                <Border
                                    Grid.Column="0"
                                    Padding="15,10"
                                    Background="#E3F2FD"
                                    CornerRadius="4"
                                    Visibility="{Binding CurrentStep.HasBolts, Converter={StaticResource LocalBoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Foreground="#1976D2"
                                            Text="🔩 Ốc vít" />
                                        <TextBlock
                                            Margin="0,5,0,0"
                                            FontSize="14"
                                            Foreground="#0D47A1"
                                            Text="{Binding CurrentStep.Bolts}" />
                                    </StackPanel>
                                </Border>

                                <!--  Force  -->
                                <Border
                                    Grid.Column="2"
                                    Padding="15,10"
                                    Background="#FFF3E0"
                                    CornerRadius="4"
                                    Visibility="{Binding CurrentStep.HasForce, Converter={StaticResource LocalBoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Foreground="#F57C00"
                                            Text="⚡ Lực siết" />
                                        <TextBlock
                                            Margin="0,5,0,0"
                                            FontSize="14"
                                            Foreground="#E65100"
                                            Text="{Binding CurrentStep.Force}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!--  Navigation Buttons  -->
                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Width="150"
                            Height="40"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            Command="{Binding PreviousStepCommand}"
                            Content="◄ Bước trước"
                            Cursor="Hand"
                            Style="{StaticResource ButtonPrimary}" />

                        <Button
                            Grid.Column="1"
                            Width="150"
                            Height="40"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding NextStepCommand}"
                            Content="Bước sau ►"
                            Cursor="Hand"
                            Style="{StaticResource ButtonPrimary}" />
                    </Grid>
                </Grid>
            </Border>

            <!--  Step List Sidebar  -->
            <Border
                Grid.Column="2"
                Padding="15"
                Background="White"
                CornerRadius="8"
                Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <!--  Search Box  -->
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Sidebar Header  -->
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#424242"
                        Text="DANH SÁCH BƯỚC" />

                    <!--  Search Box  -->
                    <hc:SearchBar
                        Grid.Row="1"
                        Height="35"
                        Margin="0,0,0,15"
                        hc:InfoElement.Placeholder="Tìm kiếm bước..."
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <!--  Steps List (Interactive)  -->
                    <ListBox
                        Grid.Row="2"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding StepsView}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectedItem="{Binding CurrentStep, Mode=TwoWay}"
                        Validation.ErrorTemplate="{x:Null}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,10" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border
                                                x:Name="ItemBorder"
                                                Padding="10"
                                                Background="#F5F5F5"
                                                BorderBrush="Transparent"
                                                BorderThickness="2"
                                                CornerRadius="6">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#E3F2FD" />
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2196F3" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#EEEEEE" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Step Number/Status  -->
                                    <Border
                                        Grid.Column="0"
                                        Width="24"
                                        Height="24"
                                        Margin="0,2,0,0"
                                        VerticalAlignment="Top"
                                        CornerRadius="12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#BDBDBD" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Background" Value="#4CAF50" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                        <Setter Property="Background" Value="#2196F3" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Text="{Binding StepNumber}" />
                                    </Border>

                                    <!--  Description  -->
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="5,0,0,0"
                                        FontSize="13"
                                        Foreground="#424242"
                                        Text="{Binding Description}"
                                        TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!--  Progress Bar Footer  -->
        <!--
        <Border
            Grid.Row="2"
            Padding="20,15"
            Background="White"
            BorderBrush="#E0E0E0"
