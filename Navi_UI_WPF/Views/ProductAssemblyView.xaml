<UserControl
    x:Class="Navi_UI_WPF.Views.ProductAssemblyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Navi_UI_WPF.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Navi_UI_WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Navi_UI_WPF.ViewModels"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="#FAFAFA"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:ProductAssemblyViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="LocalBoolToVisibility" />
        <conv:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibility" />
        <conv:StepStatusToIconConverter x:Key="StepStatusToIcon" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Header  -->
            <RowDefinition Height="*" />
            <!--  Content  -->
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Padding="16,10"
            Background="{StaticResource BrandBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <!--  PO Label  -->
                    <ColumnDefinition Width="200" />
                    <!--  PO TextBox  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  PO Info Labels  -->
                    <ColumnDefinition Width="*" />
                    <!--  Spacer  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  Step Progress  -->
                </Grid.ColumnDefinitions>

                <!--  PO Label  -->
                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="PO" />

                <!--  PO Input TextBox  -->
                <hc:TextBox
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    hc:InfoElement.Placeholder="Nhập số PO..."
                    FontSize="13"
                    Text="{Binding PoNumber, UpdateSourceTrigger=PropertyChanged}" />

                <!--  PO Info: số PO + tên hàng  -->
                <StackPanel
                    Grid.Column="2"
                    Margin="20,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        FontSize="10"
                        Foreground="#90CAF9"
                        Text="Số PO" />
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{Binding PoNumber}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="10"
                        Foreground="#90CAF9"
                        Text="Tên hàng" />
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="{Binding ProductName}" />
                </StackPanel>

                <!--  Step Progress  -->
                <TextBlock
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="#E3F2FD">
                    <Run Text="Bước " />
                    <Run FontWeight="Bold" Text="{Binding CurrentStepNumber, Mode=OneWay}" />
                    <Run Text=" / " />
                    <Run Text="{Binding TotalSteps, Mode=OneWay}" />
                </TextBlock>
            </Grid>
        </Border>

        <!--  Loading Overlay  -->
        <Grid
            Grid.Row="1"
            Panel.ZIndex="999"
            Background="#80000000"
            Visibility="{Binding IsLoading, Converter={StaticResource LocalBoolToVisibility}}">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="18"
                Foreground="White"
                Text="⏳ Đang tải dữ liệu..." />
        </Grid>

        <!--  Error Message  -->
        <Border
            Grid.Row="1"
            Margin="20"
            Padding="20"
            Panel.ZIndex="998"
            Background="#FFEBEE"
            BorderBrush="#F44336"
            BorderThickness="2"
            CornerRadius="6"
            Visibility="{Binding HasError, Converter={StaticResource LocalBoolToVisibility}}">
            <StackPanel>
                <TextBlock
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#D32F2F"
                    Text="⚠️ Lỗi" />
                <TextBlock
                    Margin="0,8,0,0"
                    FontSize="13"
                    Foreground="#C62828"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
                <Button
                    Margin="0,12,0,0"
                    HorizontalAlignment="Left"
                    Command="{Binding LoadDataCommand}"
                    CommandParameter="{Binding ProductId}"
                    Content="🔄 Thử lại"
                    Style="{StaticResource BtnGhost}" />
            </StackPanel>
        </Border>

        <!--  Main Content  -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <!--  Step List LEFT  -->
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="4*" />
                <!--  Step Detail RIGHT  -->
            </Grid.ColumnDefinitions>

            <!--  ══ Step List (LEFT) ═════════════════════════════════════  -->
            <Border
                Grid.Column="0"
                Padding="12"
                Background="White"
                CornerRadius="8"
                Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!--  Title  -->
                        <RowDefinition Height="Auto" />
                        <!--  SearchBar  -->
                        <RowDefinition Height="*" />
                        <!--  DataGrid  -->
                        <RowDefinition Height="Auto" />
                        <!--  Footer Nav  -->
                    </Grid.RowDefinitions>

                    <!--  Title  -->
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextMutedBrush}"
                        Text="DANH SÁCH BƯỚC" />

                    <!--  Search  -->
                    <hc:SearchBar
                        Grid.Row="1"
                        Height="32"
                        Margin="0,0,0,10"
                        hc:InfoElement.Placeholder="Tìm kiếm bước..."
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <!--  DataGrid  -->
                    <DataGrid
                        Grid.Row="2"
                        AutoGenerateColumns="False"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        ColumnHeaderStyle="{StaticResource GridHeader}"
                        IsReadOnly="True"
                        ItemsSource="{Binding StepsView}"
                        RowStyle="{StaticResource GridRow}"
                        SelectedItem="{Binding CurrentStep, Mode=TwoWay}"
                        Style="{StaticResource CompactGrid}">
                        <DataGrid.Columns>
                            <!--  Step Badge Column  -->
                            <DataGridTemplateColumn Width="55" Header="BƯỚC">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="26"
                                            Height="26"
                                            HorizontalAlignment="Center"
                                            CornerRadius="13">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#BDBDBD" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="Background" Value="#4CAF50" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BrandBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="{Binding StepNumber}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!--  Description Column  -->
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Description}"
                                ElementStyle="{StaticResource CellText}"
                                Header="MÔ TẢ" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!--  Footer Navigation  -->
                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Command="{Binding PreviousStepCommand}"
                            Content="◄ Bước trước"
                            Style="{StaticResource BtnGhost}" />
                        <Button
                            Grid.Column="2"
                            Command="{Binding NextStepCommand}"
                            Content="Bước sau ►"
                            Style="{StaticResource BtnPrimary}" />
                    </Grid>
                </Grid>
            </Border>

            <!--  ══ Step Detail (RIGHT) ══════════════════════════════════  -->
            <Border
                Grid.Column="2"
                Background="White"
                CornerRadius="8"
                Effect="{StaticResource CardShadow}"
                Visibility="{Binding HasCurrentStep, Converter={StaticResource LocalBoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!--  Step Header  -->
                        <RowDefinition Height="2*" />
                        <!--  Image Area  -->
                        <RowDefinition Height="2*" />
                        <!--  Detail Info  -->
                    </Grid.RowDefinitions>

                    <!--  Step Header  -->
                    <Grid Grid.Row="0" Margin="16,12,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center">
                            <Run
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{StaticResource BrandBrush}"
                                Text="Bước " />
                            <Run
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="{StaticResource BrandBrush}"
                                Text="{Binding CurrentStepNumber, StringFormat={}{0}, Mode=OneWay}" />
                            <Run
                                FontSize="14"
                                Foreground="{StaticResource TextMutedBrush}"
                                Text=" — " />
                            <Run
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{Binding CurrentStep.Description}" />
                        </TextBlock>
                        <CheckBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Content="✓ Hoàn thành"
                            FontSize="13"
                            IsChecked="{Binding CurrentStep.IsCompleted}" />
                    </Grid>

                    <Rectangle
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Height="1"
                        Margin="16,0,16,0"
                        VerticalAlignment="Bottom"
                        Fill="{StaticResource BorderBrush}" />

                    <!--  ROW 1: Ảnh minh họa  -->
                    <Grid Grid.Row="1" Margin="16,10,16,0">
                        <!--  Actual Image  -->
                        <Border
                            Background="#F5F5F5"
                            ClipToBounds="True"
                            CornerRadius="6"
                            Visibility="{Binding CurrentStep.HasImages, Converter={StaticResource LocalBoolToVisibility}}">
                            <Image
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="{Binding CurrentStep.Images}"
                                Stretch="Uniform" />
                        </Border>

                        <!--  Placeholder when no image  -->
                        <Border
                            Background="#F0F0F0"
                            CornerRadius="6"
                            Visibility="{Binding CurrentStep.HasImages, Converter={StaticResource LocalBoolToVisibility}, ConverterParameter=Invert}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="40"
                                    Foreground="#BDBDBD"
                                    Text="📷" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#9E9E9E"
                                    Text="Hình ảnh minh họa" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--  ROW 2: Chi tiết công đoạn  -->
                    <Border
                        Grid.Row="2"
                        Margin="0,8,0,0"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                        <ScrollViewer Padding="16,12,16,12" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!--  Mô tả  -->
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    Text="📝 MÔ TẢ CÔNG ĐOẠN" />
                                <TextBlock
                                    Margin="0,0,0,14"
                                    FontSize="14"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{Binding CurrentStep.Description}"
                                    TextWrapping="Wrap" />

                                <!--  Chú ý  -->
                                <StackPanel Visibility="{Binding CurrentStep.HasNote, Converter={StaticResource LocalBoolToVisibility}}">
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="#E65100"
                                        Text="※ CHÚ Ý" />
                                    <Border
                                        Margin="0,0,0,14"
                                        Padding="10,8"
                                        Background="#FFF3E0"
                                        CornerRadius="4">
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="#BF360C"
                                            Text="{Binding CurrentStep.Note}"
                                            TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>

                                <!--  Thông số kỹ thuật  -->
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Ốc vít  -->
                                    <Border
                                        Grid.Column="0"
                                        Padding="12,10"
                                        Background="#E3F2FD"
                                        CornerRadius="6"
                                        Visibility="{Binding CurrentStep.HasBolts, Converter={StaticResource LocalBoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#1976D2"
                                                Text="🔩 ỐC VÍT" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="#0D47A1"
                                                Text="{Binding CurrentStep.Bolts}" />
                                        </StackPanel>
                                    </Border>

                                    <!--  Lực siết  -->
                                    <Border
                                        Grid.Column="2"
                                        Padding="12,10"
                                        Background="#FFF3E0"
                                        CornerRadius="6"
                                        Visibility="{Binding CurrentStep.HasForce, Converter={StaticResource LocalBoolToVisibility}}">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="#F57C00"
                                                Text="⚡ LỰC SIẾT" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="#E65100"
                                                Text="{Binding CurrentStep.Force}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
